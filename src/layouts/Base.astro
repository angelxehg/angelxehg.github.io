---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Absolute canonical URL. Defaults to this page's own URL on the production site. */
  canonical?: string | URL;
  /** Site-absolute path to the social card, e.g. /images/posts/foo.png */
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
}

const {
  title,
  description = "Angel Hurtado's portfolio description",
  canonical,
  image = '/images/og.image.png',
  type = 'website',
  publishedTime,
} = Astro.props;

// Only the GitHub Pages deploy should be indexed; the Netlify mirror is not.
const indexable = !process.env.NETLIFY;
const robotsContent = indexable
  ? 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
  : 'noindex, nofollow';

const ogImage = new URL(image, Astro.site);

// Always point at the production site, never at the Netlify preview host: this
// site is the canonical source for posts that are mirrored to dev.to.
const canonicalUrl = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="robots" content={robotsContent} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="Angel Hurtado's portfolio" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="google-site-verification"
      content="0hO20fg4BEvRMjuTmUHifKltClQKkc4KKlwGD9tg6"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-gray-50 dark:bg-black font-mono text-gray-900 dark:text-gray-100">
    <slot />
  </body>
</html>
