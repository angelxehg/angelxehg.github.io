---
import Base from '../../layouts/Base.astro';
import TerminalShell from '../../components/blog/TerminalShell.vue';
import PostList from '../../components/blog/PostList.vue';
import { getBuildInfo } from '../../lib/buildInfo';
import { getMirrors } from '../../lib/devto';
import { getPosts, byteSize, humanSize, isoDate } from '../../lib/posts';

const buildInfo = getBuildInfo();
const mirrors = await getMirrors();

const posts = (await getPosts()).map((post) => ({
  slug: post.id,
  title: post.data.title,
  description: post.data.description,
  date: isoDate(post.data.date),
  size: humanSize(byteSize(post)),
  tags: post.data.tags,
  mirror: mirrors.get(post.id)?.url ?? null,
}));
---

<Base
  title="Blog | Angel Hurtado"
  description="Notes on backend development, cloud infrastructure and performance by Angel Hurtado."
>
  <TerminalShell path="/blog" buildInfo={buildInfo}>
    <PostList posts={posts} />
  </TerminalShell>
</Base>
